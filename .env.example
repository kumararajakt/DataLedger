# ==========================================
# Personal Finance Tracker - Environment Variables
# ==========================================
# Copy this file to .env and update with your values

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_tracker

# ==========================================
# JWT Authentication
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars

# ==========================================
# Server Configuration
# ==========================================
PORT=3001
NODE_ENV=development
# Local dev: http://localhost:5173  |  Docker: http://localhost:8080
CLIENT_URL=http://localhost:5173

# ==========================================
# AI Integration (Phase 2)
# ==========================================
# 64-char hex string used to AES-256 encrypt stored API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string_generated_with_crypto_random

# ==========================================
# PDF Service Configuration
# ==========================================
PDF_SERVICE_URL=http://localhost:5001

# ==========================================
# Client Configuration
# ==========================================
VITE_API_URL=http://localhost:3001
